{
  "name": "genie-platform",
  "version": "0.2.2",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "turbo run dev --filter=@genie/web --filter=@genie/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test --filter=!@genie/e2e",
    "test:e2e": "pnpm --filter @genie/e2e test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4"
  }
}
