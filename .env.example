# Genie Platform — environment variables (never commit real secrets)

# ── API (apps/api/.env) ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/genie_dev
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/genie_dev
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_STORAGE_BUCKET=knowledge
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ── Web (apps/web/.env.local) — marketing + dashboard ────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Phase 4+ (AI) ────────────────────────────────────────────────────
# OPENAI_API_KEY=
# AI_DEFAULT_MODEL=gpt-4o-mini

# ── Phase 8+ (Billing) ───────────────────────────────────────────────
