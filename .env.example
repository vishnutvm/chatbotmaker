# Genie Platform — environment variables (never commit real secrets)

# ── API (apps/api/.env) ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/genie_dev
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/genie_dev
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_STORAGE_BUCKET=knowledge
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ── Web (apps/web/.env.local) — marketing + dashboard ────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Phase 4+ (AI) ────────────────────────────────────────────────────
# OPENAI_API_KEY=
# AI_DEFAULT_MODEL=gpt-4o-mini

# ── Phase 8+ (Billing) ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/dashboard/billing?billing=success&session_id={CHECKOUT_SESSION_ID}
# STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/dashboard/billing?billing=cancel
# STRIPE_PORTAL_RETURN_URL=http://localhost:3000/dashboard/billing

# ── MCP (IDE / Cursor — set in OS environment, not committed) ────────
# STITCH_API_KEY=your-google-stitch-api-key

# ── Widget CDN (GCS) — use .env.widget-cdn.local (gitignored) ─────────
# See docs/deployment/WIDGET_CDN.md — auth via `gcloud auth login`
# GCP_PROJECT_ID=
# GCS_WIDGET_BUCKET=genie-widget
# WIDGET_CDN_PUBLIC_URL=https://storage.googleapis.com/genie-widget/widget.js
