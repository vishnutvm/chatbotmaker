# API — copy to .env (never commit secrets)
PORT=4000
NODE_ENV=development

# Cache (memory in dev; Redis in production — swap via CACHE_PROVIDER impl)
# CACHE_DRIVER=memory
# REDIS_URL=

# Database (Phase 2+)
# MONGODB_URI=

# Auth (Phase 2+)
# JWT_SECRET=
# JWT_REFRESH_SECRET=

# Storage (Phase 5+)
# AWS_REGION=
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# AI (Phase 4+ — use AI service layer only)
# OPENAI_API_KEY=

# Payments (Phase 8+)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
