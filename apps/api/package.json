{
  "name": "@genie/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "typecheck": "tsc --noEmit",
