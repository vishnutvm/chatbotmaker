# Web app — copy to .env.local (never commit secrets)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Public widget.js URL for dashboard embed snippets.
# Production pattern (Cloudflare R2 + custom domain): https://cdn.<your-domain>/widget.js
# See docs/deployment/WIDGET_CDN.md
NEXT_PUBLIC_WIDGET_SCRIPT_URL=https://cdn.example.com/widget.js
