# E2E tests — copy to .env or set in CI secrets

# Web app URL (Playwright baseURL)
E2E_DASHBOARD_URL=http://localhost:3000
E2E_API_URL=http://localhost:4000

# Required for full auth UI tests (real Supabase project)
E2E_SUPABASE_URL=https://your-project-ref.supabase.co
E2E_SUPABASE_ANON_KEY=your-anon-key

# API database (local: start Postgres; CI uses service container)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/genie_ci
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/genie_ci
SUPABASE_JWT_SECRET=ci-test-jwt-secret-minimum-32-characters
# Optional: E2E_JWT_SECRET — defaults to SUPABASE_JWT_SECRET when unset
# API JWT verification URL — use hosted Supabase for auth-flow; localhost for HS256-only auth-api
E2E_API_SUPABASE_URL=https://your-project-ref.supabase.co
CORS_ORIGINS=http://localhost:3000

# Smoke/guards without local Postgres:
# E2E_WEB_ONLY=true pnpm --filter @genie/e2e exec playwright test --project=web
